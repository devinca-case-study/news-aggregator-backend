    "components": {
        "schemas": {
            "Article": {
                "title": "Article",
                "description": "Article resource",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "provider": {
                        "type": "string",
                        "example": "newsapi"
                    },
                    "external_id": {
                        "type": "string",
                        "example": "12345"
                    },
                    "url": {
                        "type": "string",
                        "example": "https://example.com/article"
                    },
                    "image_url": {
                        "type": "string",
                        "example": "https://picsum.photos/200"
                    },
                    "title": {
                        "type": "string",
                        "example": "Breaking News: Tech Advances"
                    },
                    "content": {
                        "type": "string",
                        "example": "Article content here..."
                    },
                    "published_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-01-01T12:00:00Z"
                    },
                    "synced_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-01-01T12:00:00Z"
                    },
                    "meta": {
                        "type": "object",
                        "example": []
                    },
                    "source": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/Source"
                            }
                        ],
                        "nullable": true
                    },
                    "categories": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Category"
                        },
                        "example": []
                    },
                    "authors": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Author"
                        },
                        "example": []
                    }
                },
                "type": "object"
            },
            "AuthUser": {
                "title": "Auth User",
                "description": "Authenticated user resource",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Jane Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "jane@example.com"
                    },
                    "is_preferences_completed": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "Author": {
                "title": "Author",
                "description": "Author resource",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "John Smith"
                    }
                },
                "type": "object"
            },
            "Category": {
                "title": "Category",
                "description": "Category resource",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Technology"
                    }
                },
                "type": "object"
            },
            "Source": {
                "title": "Source",
                "description": "Source resource",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Tech News"
                    }
                },
                "type": "object"
            },
            "UserPreference": {
                "title": "User Preference",
                "description": "User preferences resource",
                "properties": {
                    "categories": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Category"
                        },
                        "example": [
                            {
                                "id": 1,
                                "name": "Technology"
                            }
                        ]
                    },
                    "sources": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Source"
                        },
                        "example": [
                            {
                                "id": 1,
                                "name": "Tech News"
                            }
                        ]
                    },
                    "authors": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Author"
                        },
                        "example": [
                            {
                                "id": 1,
                                "name": "John Smith"
                            }
                        ]
                    },
                    "preferences_completed_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-01-01T00:00:00Z",
                        "nullable": true
                    },
                    "is_preferences_completed": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
